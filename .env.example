# --- Vite (safe to commit; no API secrets) ---
# Public anon key + project URL (same as Supabase project settings → API; safe in browser)
# VITE_SUPABASE_URL=https://xxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ... (anon public key, NOT the service role)

# Leave empty on Vercel (same origin). For local: run `vercel dev` or set your API base.
# VITE_API_BASE_URL=http://localhost:3000

# --- Vercel serverless only (set in Vercel Project → Environment Variables) ---
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_ANON_KEY=eyJ... (same value as VITE_SUPABASE_ANON_KEY — used by /api/auth/login)
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Site URL for password reset emails (include https). Example:
# SITE_URL=https://www.pulseprep.com.pk
# RESEND_API_KEY=re_...
# RESEND_FROM=noreply@yourdomain.com
# RESEND from must use a domain verified in Resend. Or use Resend's onboarding domain for tests.
# EMAIL_APP_NAME=PulsePrep

# Long random string (e.g. openssl rand -base64 48) — never commit real values
# OTP_PEPPER=
# JWT_SECRET=

# Comma-separated (production CORS for browser calls to /api)
# ALLOWED_ORIGINS=https://your-app.vercel.app
